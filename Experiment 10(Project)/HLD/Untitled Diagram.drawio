<mxfile host="app.diagrams.net">
  <diagram name="Hotel Booking HLD">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- USER -->
        <mxCell id="user" value="User / Client" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="80" y="300" width="140" height="70" as="geometry"/>
        </mxCell>

        <!-- FRONTEND -->
        <mxCell id="frontend" value="Frontend (Web / Mobile UI)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="260" y="300" width="200" height="80" as="geometry"/>
        </mxCell>

        <!-- API GATEWAY -->
        <mxCell id="gateway" value="API Gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;" vertex="1" parent="1">
          <mxGeometry x="500" y="300" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- SERVICES -->
        <mxCell id="userService" value="User Service&#xa;(Auth / Profile)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="750" y="150" width="200" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="roomService" value="Room Service&#xa;(Availability / Search)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="750" y="280" width="200" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="bookingService" value="Booking Service ⭐&#xa;(Core Logic)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="750" y="410" width="200" height="80" as="geometry"/>
        </mxCell>

        <!-- CACHE -->
        <mxCell id="cache" value="Cache (Redis)" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="1000" y="150" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- DATABASE -->
        <mxCell id="db" value="Database (MySQL)" style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="1000" y="350" width="180" height="100" as="geometry"/>
        </mxCell>

        <!-- EDGES -->
        <mxCell id="e1" style="endArrow=block;" edge="1" parent="1" source="user" target="frontend">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" style="endArrow=block;" edge="1" parent="1" source="frontend" target="gateway">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" style="endArrow=block;" edge="1" parent="1" source="gateway" target="userService">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" style="endArrow=block;" edge="1" parent="1" source="gateway" target="roomService">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" style="endArrow=block;" edge="1" parent="1" source="gateway" target="bookingService">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- SERVICE TO DB -->
        <mxCell id="e6" style="endArrow=block;" edge="1" parent="1" source="userService" target="db">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" style="endArrow=block;" edge="1" parent="1" source="roomService" target="db">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e8" style="endArrow=block;" edge="1" parent="1" source="bookingService" target="db">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CACHE CONNECTION -->
        <mxCell id="e9" style="dashed=1;endArrow=block;" edge="1" parent="1" source="roomService" target="cache">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e10" style="dashed=1;endArrow=block;" edge="1" parent="1" source="bookingService" target="cache">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
